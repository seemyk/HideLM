{
    "manifest_version": 3,
    "name": "HideLM",
    "version": "1.2.4",
    "description": "Hide featured notebooks on NotebookLM — dashboard section and top-nav tab.",
    "browser_specific_settings": {
        "gecko": {
            "id": "seemyk1+info@gmail.com",
            "strict_min_version": "121.0"
        }
    },
    "icons": {
        "16": "Assets/store_icon.png",
        "48": "Assets/store_icon.png",
        "128": "Assets/store_icon.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://notebooklm.google.com/*"
            ],
            "css": [
                "styles.css"
            ],
            "run_at": "document_idle"
        }
    ]
}
