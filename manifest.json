{
    "manifest_version": 3,
    "name": "HideLM",
    "version": "1.2.5",
    "description": "Hide featured notebooks on NotebookLM — dashboard section and top-nav tab.",
    "browser_specific_settings": {
        "gecko": {
            "id": "{e52c77f0-a814-4ad9-bedb-992d83faf02d}",
            "strict_min_version": "121.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "icons": {
        "16": "Assets/icon-16.png",
        "48": "Assets/icon-48.png",
        "128": "Assets/icon-128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://notebooklm.google.com/*"
            ],
            "css": [
                "styles.css"
            ],
            "run_at": "document_idle"
        }
    ]
}
