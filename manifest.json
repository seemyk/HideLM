{
    "manifest_version": 3,
    "name": "No Featured NotebookLM",
    "version": "1.2.2",
    "description": "Hides the Featured Notebooks section and its top-nav tab on NotebookLM.",
    "content_scripts": [
        {
            "matches": [
                "https://notebooklm.google.com/*"
            ],
            "css": [
                "styles.css"
            ],
            "run_at": "document_idle"
        }
    ]
}
